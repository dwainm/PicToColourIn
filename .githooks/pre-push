#!/bin/bash
# Pre-push hook: Build WASM and auto-commit changes before pushing
# REQUIRES: Emscripten must be installed locally to compile fresh WASM

echo "🔧 Pre-push hook: Building WASM..."

# Get the git root directory
PROJECT_DIR=$(git rev-parse --show-toplevel)
cd "$PROJECT_DIR"

# Add common Emscripten locations to PATH
export PATH="$HOME/emsdk:$HOME/emsdk/upstream/emscripten:$PATH"

# Require Emscripten for build (no copying allowed)
export REQUIRE_EMSCRIPTEN=1

# Run the build script
if ./build.sh; then
    echo "✅ WASM build successful"
else
    echo "❌ WASM build failed - push aborted"
    exit 1
fi

# Check if WASM files changed
if ! git diff --quiet HEAD -- src-js/imgproc-wasm.* 2>/dev/null || ! git diff --quiet HEAD -- dist/imgproc-wasm.* 2>/dev/null; then
    echo ""
    echo "📝 WASM files changed - auto-committing..."
    
    # Stage the WASM files
    git add src-js/imgproc-wasm.js src-js/imgproc-wasm.wasm dist/imgproc-wasm.js dist/imgproc-wasm.wasm 2>/dev/null || true
    
    # Commit with a standard message
    git commit -m "🔧 Auto: update compiled WASM [pre-push hook]"
    
    echo "✅ WASM changes committed"
fi

echo "✅ All checks passed - pushing..."
exit 0
